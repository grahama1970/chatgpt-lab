{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grahama1970.github.io/chatgpt-lab/schemas/goal-capsule.schema.json",
  "title": "PhatGPT-LAB Goal Capsule",
  "type": "object",
  "required": [
    "schema",
    "goal_id",
    "version",
    "status",
    "owner",
    "immutable_goal",
    "success_criteria",
    "constraints",
    "non_goals",
    "human_change_required_for",
    "created_by",
    "created_at",
    "goal_hash"
  ],
  "properties": {
    "schema": {"const": "chatgpt_lab.goal_capsule.v1"},
    "goal_id": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "status": {"enum": ["active", "superseded", "paused"]},
    "owner": {"const": "human"},
    "immutable_goal": {"type": "string", "minLength": 1},
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "constraints": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "non_goals": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "human_change_required_for": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "created_by": {"const": "human"},
    "created_at": {"type": "string", "minLength": 1},
    "goal_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  },
  "additionalProperties": false
}
