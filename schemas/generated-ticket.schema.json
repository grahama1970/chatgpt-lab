{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grahama1970.github.io/chatgpt-lab/schemas/generated-ticket.schema.json",
  "title": "PhatGPT-LAB Generated Ticket",
  "type": "object",
  "required": [
    "schema",
    "goal",
    "ticket",
    "handoff",
    "github",
    "goal_amendment_proposal"
  ],
  "properties": {
    "schema": {"const": "chatgpt_lab.generated_ticket.v1"},
    "goal": {
      "type": "object",
      "required": ["goal_id", "goal_version", "goal_hash", "immutable_goal_preserved"],
      "properties": {
        "goal_id": {"type": "string", "minLength": 1},
        "goal_version": {"type": "integer", "minimum": 1},
        "goal_hash": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "immutable_goal_preserved": {"const": true}
      },
      "additionalProperties": false
    },
    "ticket": {
      "type": "object",
      "required": ["kind", "title", "body", "labels"],
      "properties": {
        "kind": {"enum": ["issue", "pr"]},
        "title": {"type": "string", "minLength": 1},
        "body": {"type": "string", "minLength": 1},
        "labels": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "required": ["original_goal", "fresh_context", "rationale", "next_subagent", "required_result", "stop_condition"],
      "properties": {
        "original_goal": {"type": "string", "minLength": 1},
        "fresh_context": {"type": "object"},
        "rationale": {"type": "string", "minLength": 1},
        "next": {
          "type": "object",
          "required": ["subagent", "executor", "reason", "labels"],
          "properties": {
            "subagent": {"enum": ["human", "goal-guardian", "webgpt-ticket-author", "coder", "reviewer", "releaser"]},
            "executor": {"enum": ["github-actions", "local", "either", "human"]},
            "reason": {"type": "string", "minLength": 1},
            "labels": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "next_subagent": {"enum": ["human", "goal-guardian", "webgpt-ticket-author", "coder", "reviewer", "releaser"]},
        "required_result": {"type": "string", "minLength": 1},
        "stop_condition": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    },
    "github": {
      "$ref": "agent-common.schema.json#/$defs/githubProjection"
    },
    "goal_amendment_proposal": {
      "type": ["object", "null"]
    }
  },
  "additionalProperties": false
}
