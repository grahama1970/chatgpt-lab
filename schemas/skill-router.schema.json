{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChatGPT-Lab Skill Router",
  "type": "object",
  "required": [
    "schema",
    "default_chain",
    "routes",
    "updated_at"
  ],
  "properties": {
    "schema": { "const": "chatgpt_lab.skill_router.v1" },
    "default_chain": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["intent", "skills", "authority"],
        "properties": {
          "intent": { "type": "string", "minLength": 1 },
          "skills": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "authority": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "updated_at": { "type": "string", "minLength": 1 }
  },
  "additionalProperties": false
}
