{
  "schema": "chatgpt_lab.pr_local_task.v1",
  "task_id": "pr-7-evidence-001",
  "command": "validate_only",
  "mode": "evidence_collection",
  "target": {
    "repository": "grahama1970/chatgpt-lab",
    "pr": 7,
    "branch": "copilot/issue-5-classify-youtube-telemetry-aborts",
    "commit": null
  },
  "objective": "Collect deterministic evidence for the bounded PR and report whether the PR is ready for WebGPT review.",
  "allowed_commands": [
    "gh pr view",
    "gh workflow run",
    "gh run view",
    "gh run download",
    "python3 scripts/validate_control_plane.py"
  ],
  "allowed_paths": [
    "artifacts/local-worker/**",
    "iterations/**"
  ],
  "forbidden_paths": [
