  "required_outputs": [
    "local-subagent-receipt.json",
    "artifact-manifest.json"
  ],
  "stop_condition": "PR has source check, benchmark, Pages proof, and a receipt comment for the exact PR head commit.",
  "refusal_conditions": [
    "missing_structured_task_block",
    "task_not_implementation_ready",
    "command_not_allowlisted",
    "path_outside_allowlist",
    "secrets_requested",
    "unsafe_git_operation",
    "unclear_acceptance_criteria",
